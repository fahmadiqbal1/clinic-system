APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=clinic_system
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

MEDGEMMA_PROVIDER=ollama
MEDGEMMA_MODEL=medgemma
MEDGEMMA_API_URL=http://localhost:11434
HUGGINGFACE_API_KEY=

# Phase 0 — Guardrails
# Generate with: php -r "echo base64_encode(random_bytes(32));"
CLINIC_CASE_TOKEN_SECRET=
# Password for the read-only MySQL sidecar user (created by Phase 0 migration).
CLINIC_RO_PASSWORD=

# Phase 2 — Python AI Sidecar
# URL where the FastAPI sidecar is reachable from Laravel (native: http://localhost:8001; Docker: http://sidecar:8001)
CLINIC_SIDECAR_URL=http://localhost:8001
# HS256 JWT secret shared between Laravel and the sidecar. Generate with: php -r "echo base64_encode(random_bytes(32));"
CLINIC_SIDECAR_JWT_SECRET=

# Phase 3 — RAGFlow
RAGFLOW_API_KEY=
RAGFLOW_DATASET_GENERAL=
RAGFLOW_DATASET_CATALOG=
RAGFLOW_DATASET_INVENTORY=
RAGFLOW_MINIO_USER=ragflow
RAGFLOW_MINIO_PASSWORD=
RAGFLOW_MYSQL_ROOT_PASSWORD=
RAGFLOW_MYSQL_PASSWORD=

# Phase 6 — Forecast sidecar DB (passed to Docker sidecar; mirrors Phase 0 CLINIC_RO_PASSWORD above)
# DB_HOST / DB_PORT / DB_DATABASE re-use the values already set above — no new vars needed in native mode.
# In Docker: the sidecar reads CLINIC_RO_HOST=host.docker.internal automatically via docker-compose.ai.yml.

# Phase 5 — Observability (optional — only needed when Prometheus + Grafana containers are started)
# URL of the Grafana UI (docker-compose.ai.yml optional service).
CLINIC_GRAFANA_URL=http://localhost:3000
# Grafana admin password for the optional observability stack.
GRAFANA_ADMIN_PASSWORD=

# Phase 4 — NocoBase property & equipment admin
# HMAC-SHA256 secret for webhook calls from NocoBase → Laravel. Generate: php -r "echo base64_encode(random_bytes(32));"
CLINIC_NOCOBASE_WEBHOOK_SECRET=
# Postgres password for NocoBase's own database (never touches the app's MariaDB).
NOCOBASE_DB_PASSWORD=
# Random app key for NocoBase. Generate: php -r "echo base64_encode(random_bytes(32));"
NOCOBASE_APP_KEY=
# URL where NocoBase UI is accessible (default: http://localhost:13000).
NOCOBASE_URL=http://localhost:13000
