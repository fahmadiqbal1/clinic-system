# AI Provider (groq | ollama)
AI_PROVIDER=groq

# Groq (when AI_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (when AI_PROVIDER=ollama)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b

# Per-persona model overrides (optional)
OLLAMA_MODEL_PERSONA=llama3.1:8b
OLLAMA_MODEL_ADMIN=
OLLAMA_MODEL_OPS=
OLLAMA_MODEL_COMPLIANCE=

# JWT Auth (shared with Laravel CLINIC_SIDECAR_JWT_SECRET)
SIDECAR_JWT_SECRET=

# RAGFlow
RAGFLOW_URL=http://ragflow:9380
RAGFLOW_API_KEY=
RAGFLOW_DATASET_GENERAL=general
RAGFLOW_DATASET_CATALOG=service_catalog
RAGFLOW_DATASET_INVENTORY=inventory

# Database read-only (for forecasting)
CLINIC_RO_HOST=mysql
CLINIC_RO_PORT=3306
CLINIC_RO_DATABASE=clinic_system
CLINIC_RO_USER=clinic_ro
CLINIC_RO_PASSWORD=

# Redis state store
REDIS_URL=redis://:REDIS_PASSWORD_HERE@redis:6379/1

# Alerting
CLINIC_LOW_CONFIDENCE_THRESHOLD=0.35
CLINIC_ALERT_WEBHOOK_URL=
CLINIC_ALERT_WEBHOOK_SECRET=
