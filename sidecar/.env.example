# ── Global AI provider (groq | ollama | openai | anthropic | huggingface) ──
AI_MODEL_PROVIDER=groq

# ── Groq (recommended — free tier, zero data retention available) ──────────
# Single key used by all personas unless a persona-specific key is set below.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Per-persona Groq key overrides (optional — use separate Groq projects to
# isolate rate limits between clinical and business intelligence personas).
GROQ_API_KEY_CLINICAL=
GROQ_MODEL_CLINICAL=llama-3.3-70b-versatile
GROQ_API_KEY_ADMIN=
GROQ_MODEL_ADMIN=llama-3.3-70b-versatile
GROQ_API_KEY_OPS=
GROQ_MODEL_OPS=llama-3.3-70b-versatile
GROQ_API_KEY_COMPLIANCE=
GROQ_MODEL_COMPLIANCE=llama-3.3-70b-versatile

# Per-persona provider overrides (optional — e.g. force compliance to ollama)
# AI_MODEL_PROVIDER_CLINICAL=groq
# AI_MODEL_PROVIDER_ADMIN=groq
# AI_MODEL_PROVIDER_OPS=groq
# AI_MODEL_PROVIDER_COMPLIANCE=groq

# ── Ollama (local, no data leaves) ─────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_MODEL_PERSONA=llama3.1:8b
OLLAMA_MODEL_ADMIN=
OLLAMA_MODEL_OPS=
OLLAMA_MODEL_COMPLIANCE=

# JWT Auth (shared with Laravel CLINIC_SIDECAR_JWT_SECRET)
SIDECAR_JWT_SECRET=

# RAGFlow
RAGFLOW_URL=http://ragflow:9380
RAGFLOW_API_KEY=
RAGFLOW_DATASET_GENERAL=general
RAGFLOW_DATASET_CATALOG=service_catalog
RAGFLOW_DATASET_INVENTORY=inventory

# Database read-only (for forecasting)
CLINIC_RO_HOST=mysql
CLINIC_RO_PORT=3306
CLINIC_RO_DATABASE=clinic_system
CLINIC_RO_USER=clinic_ro
CLINIC_RO_PASSWORD=

# Redis state store
REDIS_URL=redis://:REDIS_PASSWORD_HERE@redis:6379/1

# Alerting
CLINIC_LOW_CONFIDENCE_THRESHOLD=0.35
CLINIC_ALERT_WEBHOOK_URL=
CLINIC_ALERT_WEBHOOK_SECRET=
